#!/usr/bin/env bash
# Azure 開発サーバー (devbox) に接続する。
#   - 停止中(deallocated)なら自動で起動してから SSH する
#   - 22番に到達できない場合は現在の公開IPを NSG に自動追加して再接続する
#   - az 未導入 / 未ログイン / 接続失敗時はローカルのログインシェルにフォールバック
#   - SSH を抜けた後もローカルシェルに戻る
#
# 環境変数で上書き可:
#   DEVBOX_RG / DEVBOX_VM / DEVBOX_USER / DEVBOX_IP
#   DEVBOX_NSG_RG / DEVBOX_NSG / DEVBOX_NSG_RULE
set -uo pipefail

RG="${DEVBOX_RG:-rg-devbox}"
VM="${DEVBOX_VM:-devbox}"
USER_NAME="${DEVBOX_USER:-azureuser}"
IP="${DEVBOX_IP:-20.46.165.130}"   # Standard SKU の静的 IP（停止/再開で不変）

# SSH(22番) を許可する NSG ルール（現在IPの自動追加先）
NSG_RG="${DEVBOX_NSG_RG:-$RG}"
NSG="${DEVBOX_NSG:-devboxNSG}"
NSG_RULE="${DEVBOX_NSG_RULE:-allow-ssh-home}"

# ===== 一時デバッグログ（調査用。原因判明後に削除する）=====
DBG_LOG="${DEVBOX_DEBUG_LOG:-$HOME/.cache/devbox-debug.log}"
dbg() {
  mkdir -p "$(dirname "$DBG_LOG")" 2>/dev/null
  printf '[%s] %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$*" >> "$DBG_LOG" 2>/dev/null
  # 画面出力は調査完了により停止（記録はログファイルのみ）。デバッグ時は下行を有効化:
  # printf '🐞 %s\n' "$*" >&2
}
dbg "===== devbox 起動 (pid=$$ tty=$(tty 2>/dev/null || echo '?') shell=$SHELL) ====="

# 22番への TCP 到達性を確認する（第1引数: タイムアウト秒, 既定8）
reachable() {
  timeout "${1:-8}" bash -c "cat < /dev/null > /dev/tcp/${IP}/22" 2>/dev/null
}

# 現在の公開IPを取得する
current_ip() {
  curl -fsS --max-time 5 https://api.ipify.org 2>/dev/null \
    || curl -fsS --max-time 5 https://ifconfig.me 2>/dev/null
}

# 現在の公開IPを NSG ルールの許可送信元に追加する（既に許可済みなら何もしない）
allow_current_ip() {
  local cur existing
  cur=$(current_ip)
  if [ -z "$cur" ]; then
    echo "⚠ 現在の公開IPを取得できませんでした。" >&2
    return 1
  fi
  existing=$(az network nsg rule show -g "$NSG_RG" --nsg-name "$NSG" -n "$NSG_RULE" \
    --query "sourceAddressPrefixes" -o tsv 2>/dev/null)
  if [ -z "$existing" ]; then
    existing=$(az network nsg rule show -g "$NSG_RG" --nsg-name "$NSG" -n "$NSG_RULE" \
      --query "sourceAddressPrefix" -o tsv 2>/dev/null)
  fi
  if printf '%s\n' $existing | grep -qx "${cur}/32"; then
    dbg "NSG: 現在IP ${cur} は既に許可済み"
    return 0
  fi
  echo "🔓 公開IP ${cur} を NSG(${NSG_RULE}) に追加します..." >&2
  dbg "NSG: 現在IP ${cur} を追加（既存=${existing//$'\n'/ }）"
  az network nsg rule update -g "$NSG_RG" --nsg-name "$NSG" -n "$NSG_RULE" \
    --source-address-prefixes $existing "${cur}/32" -o none
}

connect() {
  if ! command -v az >/dev/null 2>&1; then
    echo "⚠ az CLI が無いため Azure に接続できません。" >&2
    dbg "中断: az CLI が無い"
    return 1
  fi
  if ! az account show >/dev/null 2>&1; then
    echo "⚠ az 未ログインです。'az login --use-device-code' を実行してください。" >&2
    dbg "中断: az 未ログイン"
    return 1
  fi
  dbg "az ログイン済み: $(az account show --query user.name -o tsv 2>/dev/null)"

  local state
  state=$(az vm get-instance-view -g "$RG" -n "$VM" \
    --query "instanceView.statuses[?starts_with(code,'PowerState/')].code | [0]" \
    -o tsv 2>/dev/null || true)
  dbg "VM 電源状態: ${state:-unknown}"

  if [ "$state" != "PowerState/running" ]; then
    echo "▶ devbox を起動中... (現在: ${state:-unknown})"
    if ! az vm start -g "$RG" -n "$VM" -o none; then
      echo "⚠ devbox の起動に失敗しました。" >&2
      dbg "中断: az vm start 失敗"
      return 1
    fi
    dbg "VM 起動完了"
  fi

  echo "🔗 ssh ${USER_NAME}@${IP}"
  if reachable; then
    dbg "到達OK: ${IP}:22（即接続）"
  else
    echo "… ${IP}:22 に到達できません。現在の公開IPを NSG に反映して再試行します。" >&2
    dbg "到達NG: ${IP}:22 → NSG 反映を試行"
    if allow_current_ip; then
      for _ in $(seq 1 6); do
        sleep 3
        reachable 4 && break
      done
    fi
    if reachable 4; then
      dbg "到達OK: NSG 反映後に接続可能"
    else
      echo "⚠ ${IP}:22 に依然到達できません（NSG 反映待ち or 別要因）。" >&2
      echo "  現在の公開IP: $(current_ip || echo '取得失敗')" >&2
      dbg "中断: NSG 反映後も到達不可"
      return 1
    fi
  fi

  dbg "ssh 接続を開始: ${USER_NAME}@${IP} (cd='${DEVBOX_CD:-}' exec='${DEVBOX_EXEC:-}')"
  # DEVBOX_CD/DEVBOX_EXEC が指定されていれば、Azure 側で cd してからコマンドを起動する
  # （nvim の agent ペインが同じプロジェクトディレクトリで claude を開く用途）。
  if [ -n "${DEVBOX_CD:-}" ] || [ -n "${DEVBOX_EXEC:-}" ]; then
    local rcmd=""
    [ -n "${DEVBOX_CD:-}" ] && rcmd="cd $(printf '%q' "$DEVBOX_CD") 2>/dev/null || true; "
    if [ -n "${DEVBOX_EXEC:-}" ]; then
      rcmd="${rcmd}exec zsh -lic $(printf '%q' "$DEVBOX_EXEC")"
    else
      rcmd="${rcmd}exec zsh -l"
    fi
    ssh -t -o StrictHostKeyChecking=accept-new -o ConnectTimeout=10 "${USER_NAME}@${IP}" "$rcmd"
  else
    ssh -o StrictHostKeyChecking=accept-new -o ConnectTimeout=10 "${USER_NAME}@${IP}"
  fi
  local rc=$?
  dbg "ssh 終了 rc=$rc（0=正常切断, それ以外=接続/認証失敗）"
  return $rc
}

if connect; then
  dbg "connect 成功 → SSH セッション終了後ローカルシェルへ"
else
  rc=$?
  dbg "connect 失敗 rc=$rc → ローカルシェルにフォールバック"
  echo "（ローカルシェルに切り替えました）" >&2
fi
dbg "exec zsh -l（ローカルシェル起動）"
exec "${SHELL:-/usr/bin/zsh}" -l
