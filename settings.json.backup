{
  "feedbackSurveyState": {
    "lastShownTime": 1754001021832
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -Command \"& 'C:\\Users\\SeiyaKawashima\\.claude\\windows-notify.ps1' -Title '[Claude Code] 応答完了' -Message 'アシスタントの応答が完了しました' -Sound 'Default'\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -Command \"$input = '${INPUT}'; if ($input -match 'git\\s+(add|commit|push|merge)' -and $input -notmatch 'git\\s+(branch|checkout)') { $branch = git branch --show-current 2>$null; if ($branch -eq 'main' -or $branch -eq 'master') { Write-Host '⚠️ WARNING: mainブランチで作業しています！'; Write-Host 'featureブランチを作成してください:'; Write-Host '  git checkout -b feature/名前'; & 'C:\\Users\\SeiyaKawashima\\.claude\\windows-notify.ps1' -Title '[警告] mainブランチ' -Message 'mainブランチで変更を加えようとしています' -Sound 'Reminder'; exit 1 } }\""
          }
        ]
      }
    ]
  }
}