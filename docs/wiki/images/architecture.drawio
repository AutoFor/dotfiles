<mxfile>
  <diagram name="dotfiles アーキテクチャ" id="arch">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="dotfiles アーキテクチャ" style="text;html=1;fontSize=20;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="350" y="20" width="300" height="30" as="geometry" />
        </mxCell>

        <!-- dotfiles repo -->
        <mxCell id="repo" value="~/dotfiles/" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="390" y="70" width="220" height="40" as="geometry" />
        </mxCell>

        <!-- WSL dir -->
        <mxCell id="wsl_dir" value="wsl/&#xa;.zshrc, .bashrc&#xa;.gitconfig&#xa;.config/gh/, .config/git/" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=center;" vertex="1" parent="1">
          <mxGeometry x="80" y="170" width="200" height="80" as="geometry" />
        </mxCell>

        <!-- Windows dir -->
        <mxCell id="win_dir" value="windows/&#xa;.wezterm.lua&#xa;.gitconfig, .bashrc" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=center;" vertex="1" parent="1">
          <mxGeometry x="400" y="170" width="200" height="80" as="geometry" />
        </mxCell>

        <!-- Claude dir -->
        <mxCell id="claude_dir" value="claude/ (サブモジュール)&#xa;CLAUDE.md, settings.json&#xa;skills/, mcp/" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=center;" vertex="1" parent="1">
          <mxGeometry x="720" y="170" width="220" height="80" as="geometry" />
        </mxCell>

        <!-- Arrows from repo -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="repo" target="wsl_dir" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="repo" target="win_dir" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="repo" target="claude_dir" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- install.sh -->
        <mxCell id="install_sh" value="install.sh" style="shape=hexagon;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="310" width="160" height="40" as="geometry" />
        </mxCell>

        <!-- install-windows.ps1 -->
        <mxCell id="install_ps1" value="install-windows.ps1" style="shape=hexagon;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="420" y="310" width="160" height="40" as="geometry" />
        </mxCell>

        <!-- Arrows to installers -->
        <mxCell id="e4" value="シンボリックリンク作成" style="edgeStyle=orthogonalEdgeStyle;dashed=1;" edge="1" source="wsl_dir" target="install_sh" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e5" value="シンボリックリンク作成" style="edgeStyle=orthogonalEdgeStyle;dashed=1;" edge="1" source="win_dir" target="install_ps1" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- WSL target -->
        <mxCell id="wsl_target" value="WSL ホームディレクトリ&#xa;~/.zshrc&#xa;~/.bashrc&#xa;~/.gitconfig&#xa;~/.config/gh/, ~/.config/git/&#xa;~/.claude/" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=center;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="410" width="260" height="100" as="geometry" />
        </mxCell>

        <!-- Windows target -->
        <mxCell id="win_target" value="Windows ホームディレクトリ&#xa;~/.wezterm.lua&#xa;~/.gitconfig&#xa;~/.bashrc" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=center;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="380" y="410" width="220" height="100" as="geometry" />
        </mxCell>

        <!-- Arrows to targets -->
        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="install_sh" target="wsl_target" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="install_ps1" target="win_target" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- GitHub Actions -->
        <mxCell id="gh_actions" value="GitHub Actions&#xa;(wiki-sync.yml)" style="shape=process;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=center;" vertex="1" parent="1">
          <mxGeometry x="720" y="310" width="180" height="40" as="geometry" />
        </mxCell>

        <!-- docs/wiki -->
        <mxCell id="docs_wiki" value="docs/wiki/&#xa;→ GitHub Wiki に自動同期" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=center;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="720" y="410" width="180" height="60" as="geometry" />
        </mxCell>

        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="gh_actions" target="docs_wiki" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Legend -->
        <mxCell id="legend_title" value="凡例" style="text;html=1;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="560" width="60" height="20" as="geometry" />
        </mxCell>
        <mxCell id="leg1" value="" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="50" y="585" width="20" height="15" as="geometry" />
        </mxCell>
        <mxCell id="leg1t" value="WSL 設定" style="text;html=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="75" y="583" width="80" height="20" as="geometry" />
        </mxCell>
        <mxCell id="leg2" value="" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="170" y="585" width="20" height="15" as="geometry" />
        </mxCell>
        <mxCell id="leg2t" value="Windows 設定" style="text;html=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="195" y="583" width="100" height="20" as="geometry" />
        </mxCell>
        <mxCell id="leg3" value="" style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="310" y="585" width="20" height="15" as="geometry" />
        </mxCell>
        <mxCell id="leg3t" value="Claude Code 設定" style="text;html=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="335" y="583" width="120" height="20" as="geometry" />
        </mxCell>
        <mxCell id="leg4" value="" style="shape=hexagon;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="470" y="585" width="20" height="15" as="geometry" />
        </mxCell>
        <mxCell id="leg4t" value="インストーラ" style="text;html=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="495" y="583" width="80" height="20" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
