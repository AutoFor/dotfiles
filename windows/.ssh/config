# ===== Windows 用 SSH 設定 (dotfiles 管理: windows/.ssh/config) =====
# devbox: 全クライアント共通の入口 (#214 Phase 3)
# WezTerm(ネイティブSSHドメイン) はこのファイルを使わず .wezterm.lua の定義で接続する。
# ssh/scp/gh 等のコマンドラインからは `ssh devbox` で入る。
# azureuser は旧エイリアス（互換用）。
# 接続は Tailscale 経由 (#214 Phase 4)。IP はノード固有で不変。MagicDNS: devbox.tail7bb5be.ts.net
Host devbox azureuser
    HostName 100.126.96.27
    User azureuser
    IdentityFile ~/.ssh/id_ed25519
    IdentitiesOnly yes
    ServerAliveInterval 30
    ServerAliveCountMax 4

# 公開 IP 直結のフォールバック（Tailscale 障害時用）。
# NSG が送信元 IP を制限しているため、先に `devbox.ps1 nsg` で現在 IP を許可すること。
Host devbox-public
    HostName 20.46.165.130
    User azureuser
    IdentityFile ~/.ssh/id_ed25519
    IdentitiesOnly yes
    ServerAliveInterval 30
    ServerAliveCountMax 4
